  "config": {
    "_note": "Backend behavioral knobs (timeouts, retries, reminder windows, caps). 'auto' tier — tuning/vendor-driven; an AI may propose updates for review. Pure-internal math constants (the token-estimate divisor and PBKDF2 iteration count) intentionally stay in code because changing them silently affects correctness, not behavior tuning.",
    "autonomy": "auto",
    "timeoutsSeconds": {
      "chat": 30,
      "grounding": 40,
      "stepSuggestion": 20,
      "sideEffects": 30,
      "documentExtraction": 60,
      "smartFill": 45,
      "clinicalApi": 5
    },
    "retry": {
      "maxAttempts": 3,
      "backoffsMs": [0, 500, 2000],
      "rateLimitBackoffSeconds": 10
    },
    "reminders": {
      "renewalWindowDays": 28,
      "checkInWindowDays": 90,
      "renewalCooldownDays": 7,
      "checkInCooldownDays": 90
    },
    "sessionCacheMinutes": 10,
    "clinical": {
      "cacheHours": 12,
      "maxCacheEntries": 500,
      "maxRequestsPerSecond": 20
    },
    "aiInput": {
      "maxIcdConditions": 30,
      "maxMedicationsPerCategory": 50,
      "maxFieldChars": 2000,
      "maxImageDimension": 1024,
      "jpegQuality": 75
    },
    "maxChatMessages": 100,
    "maxUploadBytes": 10485760,
    "textFieldMaxChars": 2000,
    "medicationNoteMaxChars": 500
  },
